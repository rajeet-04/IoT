{
  "name": "iot-backend",
  "version": "1.0.0",
  "description": "IoT Device Control Platform backend server",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "server": "nodemon src/index.js",
