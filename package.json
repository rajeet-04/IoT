    "dotenv": "^16.6.1",
    "ethers": "^6.17.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.5.0",
    "mongoose": "^8.24.1",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "concurrently": "^9.2.4",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14"
